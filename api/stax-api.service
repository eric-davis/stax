[Unit]
Description=STAX Leaderboard API
After=network.target

[Service]
User=www-data
WorkingDirectory=/var/www/esdavis.dev/stax/api
Environment=STAX_DB=/var/db/stax/scores.db
ExecStart=/var/www/esdavis.dev/stax/api/.venv/bin/gunicorn app:app -b 127.0.0.1:8766 -w 2
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
